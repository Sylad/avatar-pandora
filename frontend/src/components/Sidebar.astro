---
import EywaLogo from './EywaLogo.astro';

interface Props {
  current?: string;
}
const { current } = Astro.props;

const sections = [
  { slug: 'pandora', label: 'Pandora', href: '/pandora/' },
  { slug: 'clans', label: 'Clans Na\'vi', href: '/clans/' },
  { slug: 'bestiaire', label: 'Bestiaire', href: '/bestiaire/' },
  { slug: 'flore', label: 'Flore', href: '/flore/' },
  { slug: 'personnages', label: 'Personnages', href: '/personnages/' },
  { slug: 'langue', label: 'Langue Na\'vi', href: '/langue/' },
  { slug: 'films', label: 'Les films', href: '/films/' },
  { slug: 'engins', label: 'Engins', href: '/engins/' },
  { slug: 'videos', label: 'Vidéos', href: '/videos/' },
];
---
<!--
  Mobile (<lg) : drawer slide-in depuis la gauche, contrôlé par data-drawer-open
  sur <html>. Bouton burger et overlay vivent dans CodexLayout.
  Desktop (>=lg) : sidebar 320px sticky comme avant.
-->
<aside
  id="eywa-sidebar"
  class="eywa-sidebar fixed lg:sticky inset-y-0 left-0 z-50 w-80 shrink-0 lg:top-0 h-screen overflow-y-auto px-6 py-10 flex flex-col -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-out"
  aria-label="Navigation du codex"
>
  <a href="/" class="block mb-10 group">
    <EywaLogo size={200} />
    <span class="block text-xs uppercase text-eywa-text-muted mt-2">Codex de Pandora</span>
  </a>

  <nav class="flex flex-col gap-1">
    {sections.map((s) => (
      <a
        href={s.href}
        class:list={[
          'eywa-nav-link block px-3 py-2 rounded text-sm font-display tracking-wide transition-all duration-300',
          current === s.slug
            ? 'is-active bg-eywa-bio-primary/10 text-eywa-bio-primary shadow-[0_0_20px_-2px_rgba(95,255,230,0.30)]'
            : 'text-eywa-text-muted hover:text-eywa-bio-primary hover:bg-eywa-bio-primary/5 hover:shadow-[0_0_18px_-4px_rgba(95,255,230,0.40)]',
        ]}
      >
        {s.label}
      </a>
    ))}
  </nav>

  <div class="eywa-about mt-auto pt-6">
    <div class="eywa-about__divider" aria-hidden="true"></div>
    <a href="/about/" class="eywa-about__link">
      <svg class="eywa-about__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="9.5" />
        <path d="M12 11v5" />
        <circle cx="12" cy="7.75" r="0.9" fill="currentColor" stroke="none" />
      </svg>
      <span>À propos</span>
    </a>
  </div>
</aside>

<style>
  /* Bioluminescent right edge: faint always, brighter via the inner shadow.
     Replaces the plain border-r so the sidebar feels alive. */
  .eywa-sidebar {
    border-right: 1px solid rgba(95, 255, 230, 0.18);
    box-shadow:
      inset -1px 0 0 rgba(95, 255, 230, 0.10),
      1px 0 30px -8px rgba(95, 255, 230, 0.18);
    /* Sur mobile (drawer fixed), opaque pour ne pas voir le main à travers. */
    background: rgba(8, 12, 22, 0.96);
    backdrop-filter: blur(8px);
  }

  /* Drawer ouvert sur mobile : translation à 0. Sur lg+, déjà à 0. */
  :global(html[data-drawer-open="true"]) .eywa-sidebar {
    transform: translateX(0);
  }

  @media (min-width: 1024px) {
    .eywa-sidebar {
      background: transparent;
      backdrop-filter: none;
    }
  }

  /* Active nav item slowly breathes — Pandora's pulse. */
  .eywa-nav-link.is-active {
    animation: eywa-breath 4s ease-in-out infinite;
  }

  @keyframes eywa-breath {
    0%, 100% {
      box-shadow: 0 0 18px -2px rgba(95, 255, 230, 0.25);
    }
    50% {
      box-shadow: 0 0 28px 0px rgba(95, 255, 230, 0.55);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .eywa-nav-link.is-active {
      animation: none;
    }
  }

  /*
    "À propos" footer link — explicitly distinct from the 9 codex sections
    above. A faint cyan divider above it severs it from the nav list, an
    info icon signals its meta nature, and the typography is bumped to the
    same .text-sm as the nav links (was .text-xs at 60% opacity, basically
    invisible on a wide sidebar). On hover the icon glows like every other
    bioluminescent affordance on the site.
  */
  .eywa-about__divider {
    height: 1px;
    margin: 0 0.25rem 0.85rem;
    background: linear-gradient(
      to right,
      transparent,
      rgba(95, 255, 230, 0.30),
      transparent
    );
  }

  .eywa-about__link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.45rem 0.75rem;
    font-family: var(--font-display);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    color: var(--color-eywa-text-muted);
    border-radius: 4px;
    transition: color 300ms ease, background-color 300ms ease, box-shadow 300ms ease;
  }

  .eywa-about__icon {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
    color: var(--color-eywa-bio-primary);
    opacity: 0.75;
    transition: opacity 300ms ease, filter 300ms ease;
  }

  .eywa-about__link:hover {
    color: var(--color-eywa-bio-primary);
    background-color: rgba(95, 255, 230, 0.06);
    box-shadow: 0 0 18px -6px rgba(95, 255, 230, 0.50);
  }

  .eywa-about__link:hover .eywa-about__icon {
    opacity: 1;
    filter: drop-shadow(0 0 6px rgba(95, 255, 230, 0.65));
  }
</style>

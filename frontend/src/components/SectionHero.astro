---
/**
 * Hero banner pour les section indexes du codex.
 * Image grand format (21:9 cinéma) avec titre + sous-titre + tagline
 * en overlay sur un dégradé qui s'éteint vers le bas pour la lisibilité.
 * Donne à chaque section un punch visuel "magazine cover" avant la grille
 * de cards.
 */
interface Props {
  roman: string;
  label: string;
  title: string;
  tagline: string;
  cover: string;
}
const { roman, label, title, tagline, cover } = Astro.props;

const imgSrc = cover.startsWith('http')
  ? cover
  : `/api/wiki-image?q=${encodeURIComponent(cover)}`;
---
<header class="section-hero">
  <img src={imgSrc} alt={title} class="section-hero__img"
       onerror="this.style.display='none'" />
  <div class="section-hero__veil"></div>
  <div class="section-hero__content">
    <p class="section-hero__roman">{roman} — {label}</p>
    <h1 class="section-hero__title">{title}</h1>
    <p class="section-hero__tagline">{tagline}</p>
  </div>
</header>

<style>
  .section-hero {
    position: relative;
    aspect-ratio: 21 / 9;
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 3rem;
    border: 1px solid rgba(232, 230, 221, 0.1);
    box-shadow:
      0 0 0 1px rgba(95, 255, 230, 0.06) inset,
      0 0 30px -8px rgba(95, 255, 230, 0.20);
  }

  .section-hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(1.05);
  }

  /*
    Multi-stop veil : bottom-left dark for the title overlay readability,
    overall slight cyan tint for the bioluminescent feel, top-right
    lighter so the image still breathes.
  */
  .section-hero__veil {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg,
        rgba(10, 10, 31, 0.70) 0%,
        rgba(10, 10, 31, 0.30) 35%,
        rgba(10, 10, 31, 0.10) 70%),
      linear-gradient(to top,
        rgba(10, 10, 31, 0.85) 0%,
        rgba(10, 10, 31, 0.20) 50%,
        transparent 100%);
  }

  .section-hero__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2.5rem 2.5rem 2rem;
  }

  .section-hero__roman {
    font-family: var(--font-display);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--color-eywa-bio-primary);
    margin-bottom: 0.75rem;
    text-shadow: 0 2px 6px rgba(10, 10, 31, 0.85);
  }

  .section-hero__title {
    font-family: var(--font-display);
    font-size: 2.75rem;
    line-height: 1.05;
    color: var(--color-eywa-text);
    text-shadow:
      0 2px 12px rgba(10, 10, 31, 0.95),
      0 0 30px rgba(95, 255, 230, 0.20);
    margin-bottom: 0.75rem;
  }

  @media (min-width: 768px) {
    .section-hero__title {
      font-size: 3.5rem;
    }
  }

  .section-hero__tagline {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 1.125rem;
    color: rgba(232, 230, 221, 0.85);
    text-shadow: 0 2px 6px rgba(10, 10, 31, 0.85);
    max-width: 40rem;
  }
</style>

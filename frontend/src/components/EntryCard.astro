---
interface Props {
  href: string;
  title: string;
  summary: string;
  cover?: string;
}
const { href, title, summary, cover } = Astro.props;

let imgSrc: string | undefined;
if (cover) {
  imgSrc = cover.startsWith('http') ? cover : `/api/wiki-image?q=${encodeURIComponent(cover)}`;
}
---
<a href={href} class="entry-card group">
  {imgSrc ? (
    <div class="entry-card__media">
      <img src={imgSrc}
           alt={title}
           loading="lazy"
           class="entry-card__img"
           onerror="this.style.display='none'" />
    </div>
  ) : (
    <div class="entry-card__media entry-card__media--placeholder">
      <span class="font-display text-eywa-bio-primary/50 tracking-widest text-sm">EYWA</span>
    </div>
  )}
  <div class="entry-card__body">
    <h3 class="entry-card__title">{title}</h3>
    <p class="entry-card__summary">{summary}</p>
  </div>
</a>

<style>
  /*
    "Pandora floor" hover effect : the card has a faint always-on cyan
    glow (it's bioluminescent at rest). On hover, a radial light blooms
    outward as if a footstep activated the moss — the image brightens,
    the title cyans, the border ignites.
  */
  .entry-card {
    position: relative;
    display: block;
    border-radius: 6px;
    overflow: hidden;
    background: rgba(232, 230, 221, 0.02);
    border: 1px solid rgba(95, 255, 230, 0.15);
    box-shadow:
      0 0 0 1px rgba(95, 255, 230, 0.04) inset,
      0 0 18px -8px rgba(95, 255, 230, 0.20);
    transition:
      border-color 400ms ease,
      box-shadow 400ms ease,
      transform 400ms ease;
  }

  /* Pseudo-element holding the radial-bloom that lights up on hover. */
  .entry-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 6px;
    pointer-events: none;
    background: radial-gradient(ellipse 80% 60% at 50% 50%,
      rgba(95, 255, 230, 0.18),
      rgba(127, 255, 143, 0.08) 40%,
      transparent 70%);
    opacity: 0;
    transition: opacity 500ms ease;
    z-index: 1;
  }

  .entry-card:hover {
    border-color: rgba(95, 255, 230, 0.55);
    box-shadow:
      0 0 0 1px rgba(95, 255, 230, 0.10) inset,
      0 0 32px -4px rgba(95, 255, 230, 0.40),
      0 0 60px -12px rgba(127, 255, 143, 0.25);
    transform: translateY(-2px);
  }

  .entry-card:hover::before {
    opacity: 1;
  }

  /*
    Tap → bloom : on tactile devices (no hover), JS intercepts the click,
    adds .is-blooming for 1.5s with a stronger glow + scale, then runs
    the navigation. Mirrors the "Pandora floor lights up under footstep"
    metaphor for fingertip taps.
  */
  .entry-card.is-blooming {
    border-color: rgba(95, 255, 230, 0.75);
    box-shadow:
      0 0 0 1px rgba(95, 255, 230, 0.20) inset,
      0 0 48px -2px rgba(95, 255, 230, 0.65),
      0 0 90px -10px rgba(127, 255, 143, 0.45);
    animation: entry-card-bloom 1500ms ease-out;
  }
  .entry-card.is-blooming::before {
    opacity: 1;
    background: radial-gradient(ellipse 90% 70% at 50% 50%,
      rgba(95, 255, 230, 0.42),
      rgba(127, 255, 143, 0.20) 40%,
      transparent 75%);
  }
  .entry-card.is-blooming .entry-card__img {
    opacity: 1;
    transform: scale(1.08);
    filter: saturate(1.20) brightness(1.12);
  }
  .entry-card.is-blooming .entry-card__title {
    color: var(--color-eywa-bio-primary);
    text-shadow: 0 0 18px rgba(95, 255, 230, 0.65);
  }

  @keyframes entry-card-bloom {
    0% {
      transform: translateY(0) scale(1);
    }
    25% {
      transform: translateY(-3px) scale(1.015);
    }
    100% {
      transform: translateY(-2px) scale(1.01);
    }
  }

  /*
    Devices without hover (touch) never see the .entry-card:hover styles
    triggered as a "stuck hover" after tap. We restore the rest state
    explicitly. The .is-blooming animation takes over on tap.
  */
  @media (hover: none) {
    .entry-card:hover {
      border-color: rgba(95, 255, 230, 0.15);
      box-shadow:
        0 0 0 1px rgba(95, 255, 230, 0.04) inset,
        0 0 18px -8px rgba(95, 255, 230, 0.20);
      transform: none;
    }
    .entry-card:hover::before {
      opacity: 0;
    }
    .entry-card:hover .entry-card__img {
      opacity: 0.78;
      transform: none;
      filter: none;
    }
    .entry-card:hover .entry-card__title {
      color: var(--color-eywa-text);
      text-shadow: none;
    }
  }

  /* Media area — taller 4:3 for more dominant Pandora imagery */
  .entry-card__media {
    position: relative;
    aspect-ratio: 4 / 3;
    background: var(--color-eywa-bg);
    overflow: hidden;
  }

  .entry-card__media--placeholder {
    background:
      radial-gradient(ellipse at 30% 30%, rgba(95, 255, 230, 0.18), transparent 60%),
      radial-gradient(ellipse at 70% 70%, rgba(127, 255, 143, 0.12), transparent 60%),
      linear-gradient(135deg, var(--color-eywa-bg), rgba(74, 74, 143, 0.20));
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .entry-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.78;
    transition: opacity 600ms ease, transform 700ms ease, filter 600ms ease;
  }

  .entry-card:hover .entry-card__img {
    opacity: 1;
    transform: scale(1.06);
    filter: saturate(1.15) brightness(1.08);
  }

  /* Body */
  .entry-card__body {
    position: relative;
    z-index: 2;
    padding: 1.25rem;
  }

  .entry-card__title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    color: var(--color-eywa-text);
    letter-spacing: 0.04em;
    margin-bottom: 0.5rem;
    transition: color 400ms ease, text-shadow 400ms ease;
  }

  .entry-card:hover .entry-card__title {
    color: var(--color-eywa-bio-primary);
    text-shadow: 0 0 14px rgba(95, 255, 230, 0.45);
  }

  .entry-card__summary {
    font-family: var(--font-body);
    /*
      Pinned to 14px (was 0.875rem = ~15.3px after the body bump) — cards
      are dense, 3-line clamp must hold across 24-entry grids (Bestiaire,
      Personnages). The contrast lift on --color-eywa-text-muted does the
      heavy lifting for readability here.
    */
    font-size: 0.8rem;
    color: var(--color-eywa-text-muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (prefers-reduced-motion: reduce) {
    .entry-card,
    .entry-card__img,
    .entry-card__title,
    .entry-card::before {
      transition: none;
    }
    .entry-card:hover {
      transform: none;
    }
    .entry-card.is-blooming {
      animation: none;
    }
  }
</style>

<script is:inline data-entry-card-tap>
  /*
    Tap-friendly bloom on .entry-card. On devices without hover
    (mobile/tablet — `(hover: none)`), we intercept the click, paint
    .is-blooming for 1.5s, then run the navigation. Honors:
      - prefers-reduced-motion → skip the bloom, navigate immediately
      - middle/cmd/ctrl/shift click → don't intercept (let new tab work)
      - already-blooming card → don't re-trigger
  */
  (() => {
    if (typeof window === 'undefined') return;
    if (window.__eywaEntryCardTapInit) return;
    window.__eywaEntryCardTapInit = true;

    const wantsBloom = () => window.matchMedia('(hover: none)').matches;
    const reducedMotion = () =>
      window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    document.addEventListener(
      'click',
      (e) => {
        const card =
          e.target instanceof Element ? e.target.closest('a.entry-card') : null;
        if (!card) return;
        if (!wantsBloom()) return;
        if (reducedMotion()) return;
        // Modifier keys → let the browser handle (new tab / new window)
        const me = e;
        if (me.metaKey || me.ctrlKey || me.shiftKey || me.altKey) return;
        if (me.button !== undefined && me.button !== 0) return;
        if (card.classList.contains('is-blooming')) return;

        const href = card.getAttribute('href');
        if (!href) return;

        e.preventDefault();
        card.classList.add('is-blooming');
        window.setTimeout(() => {
          window.location.assign(href);
        }, 1500);
      },
      // Capture phase so we run before any inner element steals the click.
      true
    );
  })();
</script>

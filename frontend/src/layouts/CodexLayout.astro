---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import { CodexAmbient } from '../components/cinema/CodexAmbient';

interface Props {
  title: string;
  current?: string;
}
const { title, current } = Astro.props;
---
<BaseLayout title={title}>
  <!--
    Layered ambient: WebGL particles (cyan/forest-green pollen at low
    density) + CSS radial gradients + cursor-follow bioluminescent halo.
    Mimics the "Pandora floor lights up under footstep" sensation across
    the entire codex.
  -->
  <!-- Forest backdrop : a real Pandora image faded behind everything. Gives
       the codex pages the sensation of reading inside the bioluminescent
       jungle rather than on a flat dark page. -->
  <div class="forest-backdrop" aria-hidden="true"></div>
  <CodexAmbient client:only="react" />
  <div class="bio-ambient" aria-hidden="true"></div>
  <div class="cursor-glow" aria-hidden="true"></div>

  <div class="flex relative">
    <Sidebar current={current} />
    <main class="flex-1 px-10 py-12 max-w-7xl">
      <slot />
    </main>
  </div>
</BaseLayout>

<script is:inline>
  // Cursor-follow bioluminescence — like the moss waking up under Jake's foot.
  // Throttled via rAF; CSS does the rendering.
  (() => {
    if (typeof window === 'undefined') return;
    const mq = window.matchMedia('(prefers-reduced-motion: reduce)');
    if (mq.matches) return;
    let pendingX = 0, pendingY = 0, ticking = false;
    const update = () => {
      document.documentElement.style.setProperty('--mx', pendingX + 'px');
      document.documentElement.style.setProperty('--my', pendingY + 'px');
      ticking = false;
    };
    window.addEventListener('mousemove', (e) => {
      pendingX = e.clientX;
      pendingY = e.clientY;
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    }, { passive: true });
  })();

  // Wrap every word of the article body into a <span class="bio-word">
  // so each word can light up cyan when the cursor hovers it.
  // Targets paragraphs only — leaves headings, links, italics intact.
  (() => {
    if (typeof window === 'undefined') return;
    const split = () => {
      const ps = document.querySelectorAll('article p, article li');
      ps.forEach((p) => {
        if (p.dataset.bioSplit === '1') return;
        // Only walk direct text-node children — preserves <em>, <a>, <strong>.
        const children = Array.from(p.childNodes);
        children.forEach((node) => {
          if (node.nodeType !== Node.TEXT_NODE) return;
          const text = node.textContent ?? '';
          if (!text.trim()) return;
          const frag = document.createDocumentFragment();
          // Split on whitespace but keep the whitespace itself so the layout doesn't change.
          const tokens = text.split(/(\s+)/);
          tokens.forEach((tok) => {
            if (/^\s+$/.test(tok) || tok === '') {
              frag.appendChild(document.createTextNode(tok));
            } else {
              const span = document.createElement('span');
              span.className = 'bio-word';
              span.textContent = tok;
              frag.appendChild(span);
            }
          });
          p.replaceChild(frag, node);
        });
        p.dataset.bioSplit = '1';
      });
    };
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', split);
    } else {
      split();
    }
    document.addEventListener('astro:page-load', split);
  })();
</script>

<style>
  /* Faded Pandora forest behind the WebGL particles. The image comes
     from /api/wiki-image?q=Pandora — Avatar Fandom returns the floating
     mountains / forest hero. Heavily blurred and faded so it reads as
     atmosphere, not foreground. */
  .forest-backdrop {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image: url('/api/wiki-image?q=Pandora');
    background-size: cover;
    background-position: center;
    opacity: 0.18;
    filter: blur(3px) saturate(1.15);
  }

  .bio-ambient {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 60% 40% at 15% 15%, rgba(95, 255, 230, 0.12), transparent 70%),
      radial-gradient(ellipse 50% 35% at 85% 35%, rgba(255, 93, 196, 0.10), transparent 70%),
      radial-gradient(ellipse 70% 50% at 50% 90%, rgba(127, 255, 143, 0.08), transparent 70%),
      radial-gradient(ellipse 40% 30% at 80% 80%, rgba(255, 140, 42, 0.06), transparent 70%);
    animation: bio-drift 28s ease-in-out infinite alternate;
  }

  /* Subtle blob drift so the wash feels alive, not static. */
  @keyframes bio-drift {
    0% {
      background-position: 0% 0%, 100% 0%, 0% 100%, 100% 100%;
    }
    100% {
      background-position: 5% 8%, 95% 6%, 4% 92%, 96% 94%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .bio-ambient {
      animation: none;
    }
  }

  /*
    Cursor-follow halo. A 360px-radius cyan glow centered on (--mx, --my).
    Pointer-events none so it doesn't capture clicks. Fades in/out via
    smooth opacity transition when the mouse stops/starts moving.
  */
  .cursor-glow {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: radial-gradient(360px circle at var(--mx, 50%) var(--my, 50%),
      rgba(95, 255, 230, 0.10),
      rgba(127, 255, 143, 0.04) 40%,
      transparent 70%);
    mix-blend-mode: screen;
    transition: background 80ms linear;
  }

  @media (prefers-reduced-motion: reduce) {
    .cursor-glow {
      display: none;
    }
  }

  /* Ensure the sidebar + main content render above the ambient layer. */
  :global(aside),
  :global(main) {
    position: relative;
    z-index: 2;
  }

  /*
    Article body text gets a soft dark text-shadow so it stays legible
    against the drifting WebGL pollen behind. Subtle — not embossed,
    just enough to lift the words above the busy background.
  */
  :global(article p),
  :global(article li),
  :global(article h1),
  :global(article h2),
  :global(article h3),
  :global(article h4) {
    text-shadow:
      0 1px 2px rgba(10, 10, 31, 0.85),
      0 0 12px rgba(10, 10, 31, 0.55);
  }

  /* Bio-word hover styles live in src/styles/global.css now — they're
     reused by the landing tagline in addition to the codex prose. */
</style>

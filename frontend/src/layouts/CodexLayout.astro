---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';

interface Props {
  title: string;
  current?: string;
}
const { title, current } = Astro.props;
---
<BaseLayout title={title}>
  <div class="flex">
    <Sidebar current={current} />
    <main class="flex-1 px-10 py-12 max-w-4xl">
      <slot />
    </main>
  </div>
</BaseLayout>

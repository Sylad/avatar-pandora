---
import { getCollection } from 'astro:content';
import CodexLayout from '../layouts/CodexLayout.astro';
import EntryCard from '../components/EntryCard.astro';
import SectionHero from '../components/SectionHero.astro';

const entries = await getCollection('films');
entries.sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
---
<CodexLayout title="Les films — Eywa" current="films">
  <SectionHero
    roman="VII"
    label="Les films"
    title="Trois œuvres, vingt-cinq ans de Pandora"
    tagline="De 2009 à 2025 — l'évolution d'une vision."
    cover="Avatar (film)"
  />
  <section class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4 gap-5">
    {entries.map((entry) => (
      <EntryCard href={`/films/${entry.id}/`} title={entry.data.title} summary={entry.data.summary} cover={entry.data.cover} />
    ))}
  </section>
</CodexLayout>

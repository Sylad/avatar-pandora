---
import EywaLogo from '../components/EywaLogo.astro';
import '../styles/global.css';
---
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Eywa — Logo preview</title>
  </head>
  <body class="bg-eywa-bg flex flex-col items-center justify-center min-h-screen gap-8 p-10">
    <!-- Large hero version with glow -->
    <EywaLogo size={400} />

    <!-- Smaller version no glow, to verify the prop works -->
    <EywaLogo size={200} glowing={false} />

    <p class="text-eywa-text-muted text-sm uppercase tracking-widest font-display">
      Logo preview — E + V (left half of W) + A in cyan
    </p>
  </body>
</html>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import EywaLogo from '../components/EywaLogo.astro';
import { CinemaCanvas } from '../components/cinema/CinemaCanvas';
import { CycleBackdrop } from '../components/cinema/CycleBackdrop';
---
<BaseLayout title="Eywa — Codex de Pandora" description="Un codex visuel de Pandora — la lune, ses clans, sa faune, sa langue.">

  <!--
    Landing — single viewport, no scroll. Behind the content :
      1. CycleBackdrop : 6 Pandora location images cross-fading on a
         75-second loop (forêt → Hometree → Hallelujah → Metkayina →
         Fire & Ash → reveal).
      2. CinemaCanvas (mode='time') : the bioluminescent particle field
         drives uniforms on the SAME 75s loop, so atmosphere colors
         match the visible image.
      3. Bio-ambient gradient (the 4 radial blobs from CodexLayout
         pattern) for global cohesion with the codex pages.
    The user sits, breathes, and Pandora transforms around them.
  -->
  <CycleBackdrop client:only="react" />
  <CinemaCanvas client:only="react" mode="time" cycleMs={75000} />
  <div class="bio-ambient" aria-hidden="true"></div>

  <main class="relative z-10 min-h-screen flex flex-col items-center justify-center text-center px-6 py-20">
    <EywaLogo size={420} />
    <p class="mt-8 max-w-xl text-eywa-text text-xl italic font-body landing-tagline" data-bio-split>
      « Je te vois. »<br/>
      Un codex visuel de Pandora — la lune, ses clans, sa faune, sa langue.
    </p>
    <div class="mt-12 flex gap-4 justify-center">
      <a href="/pandora/intro/"
         class="px-6 py-3 rounded border border-eywa-bio-primary text-eywa-bio-primary hover:shadow-glow-bio transition-shadow backdrop-blur-sm bg-eywa-bg/30">
        Explorer le codex
      </a>
      <a href="/about/"
         class="px-6 py-3 rounded text-eywa-text-muted hover:text-eywa-text transition-colors backdrop-blur-sm bg-eywa-bg/30">
        À propos
      </a>
    </div>
  </main>
</BaseLayout>

<script is:inline>
  // Wrap the landing tagline words in <span class="bio-word"> so each
  // glows cyan when the cursor passes over it — same effect as the
  // codex prose. Preserves <br> and other inline elements.
  (() => {
    if (typeof window === 'undefined') return;
    const split = () => {
      const targets = document.querySelectorAll('[data-bio-split]');
      targets.forEach((p) => {
        if (p.dataset.bioSplitDone === '1') return;
        Array.from(p.childNodes).forEach((node) => {
          if (node.nodeType !== Node.TEXT_NODE) return;
          const text = node.textContent ?? '';
          if (!text.trim()) return;
          const frag = document.createDocumentFragment();
          text.split(/(\s+)/).forEach((tok) => {
            if (/^\s+$/.test(tok) || tok === '') {
              frag.appendChild(document.createTextNode(tok));
            } else {
              const span = document.createElement('span');
              span.className = 'bio-word';
              span.textContent = tok;
              frag.appendChild(span);
            }
          });
          p.replaceChild(frag, node);
        });
        p.dataset.bioSplitDone = '1';
      });
    };
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', split);
    } else {
      split();
    }
    document.addEventListener('astro:page-load', split);
  })();
</script>

<style>
  /*
    The cycling images are vivid — the foreground content needs a hint
    of dark veil under it for legibility. A bottom-up gradient does the
    job without darkening the whole viewport.
  */
  main::before {
    content: '';
    position: fixed;
    inset: 0;
    z-index: 5;
    pointer-events: none;
    background: linear-gradient(to bottom,
      rgba(10, 10, 31, 0.30) 0%,
      rgba(10, 10, 31, 0.55) 100%);
  }

  /* Tagline + logo get a stronger halo for readability above the
     vivid Pandora images cycling underneath. Two layers : a tight
     dark drop-shadow for crisp legibility, then a soft cyan glow that
     ties it back to the bioluminescent palette. */
  .landing-tagline {
    text-shadow:
      0 2px 8px rgba(10, 10, 31, 0.95),
      0 0 18px rgba(10, 10, 31, 0.85),
      0 0 30px rgba(95, 255, 230, 0.15);
  }

  /* Bio-ambient gradient — same recipe as CodexLayout but slightly
     louder since the backdrop is more vivid here. */
  .bio-ambient {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      radial-gradient(ellipse 60% 40% at 15% 15%, rgba(95, 255, 230, 0.10), transparent 70%),
      radial-gradient(ellipse 50% 35% at 85% 35%, rgba(255, 93, 196, 0.08), transparent 70%),
      radial-gradient(ellipse 70% 50% at 50% 90%, rgba(127, 255, 143, 0.08), transparent 70%);
  }
</style>

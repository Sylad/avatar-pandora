---
import { getCollection } from 'astro:content';
import CodexLayout from '../layouts/CodexLayout.astro';
import EntryCard from '../components/EntryCard.astro';
import SectionHero from '../components/SectionHero.astro';

const entries = await getCollection('bestiaire');
entries.sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
---
<CodexLayout title="Bestiaire — Eywa" current="bestiaire">
  <SectionHero
    roman="III"
    label="Bestiaire"
    title="La faune de Pandora"
    tagline="Ikran, toruk, thanator — créatures sublimes et létales."
    cover="Toruk Makto"
  />
  <section class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4 gap-5">
    {entries.map((entry) => (
      <EntryCard href={`/bestiaire/${entry.id}/`} title={entry.data.title} summary={entry.data.summary} cover={entry.data.cover} />
    ))}
  </section>
</CodexLayout>

---
import { getCollection } from 'astro:content';
import CodexLayout from '../layouts/CodexLayout.astro';
import EntryCard from '../components/EntryCard.astro';
import SectionHero from '../components/SectionHero.astro';

const entries = await getCollection('pandora');
entries.sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
---
<CodexLayout title="Pandora — Eywa" current="pandora">
  <SectionHero
    roman="I"
    label="Pandora"
    title="La lune jungle"
    tagline="Lune habitable d'Alpha Centauri A, foyer des Na'vi et de la conscience-réseau Eywa."
    cover="Pandora"
  />
  <section class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4 gap-5">
    {entries.map((entry) => (
      <EntryCard
        href={`/pandora/${entry.id}/`}
        title={entry.data.title}
        summary={entry.data.summary}
        cover={entry.data.cover}
      />
    ))}
  </section>
</CodexLayout>

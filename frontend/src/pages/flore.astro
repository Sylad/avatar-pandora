---
import { getCollection } from 'astro:content';
import CodexLayout from '../layouts/CodexLayout.astro';
import EntryCard from '../components/EntryCard.astro';
import SectionHero from '../components/SectionHero.astro';

const entries = await getCollection('flore');
entries.sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
---
<CodexLayout title="Flore — Eywa" current="flore">
  <SectionHero
    roman="IV"
    label="Flore"
    title="Les arbres-réseaux et plantes sacrées"
    tagline="Hometree, Arbre des Âmes, racines connectées par milliers de kilomètres."
    cover="Tree of Souls"
  />
  <section class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4 gap-5">
    {entries.map((entry) => (
      <EntryCard href={`/flore/${entry.id}/`} title={entry.data.title} summary={entry.data.summary} cover={entry.data.cover} />
    ))}
  </section>
</CodexLayout>

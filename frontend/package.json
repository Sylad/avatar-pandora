{
  "name": "frontend",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "predev": "node -e \"const f=require('node:fs');const p='../scripts/sync-shared.cjs';if(f.existsSync(p))require('node:child_process').execSync('node '+p,{stdio:'inherit'});\"",
    "prebuild": "node -e \"const f=require('node:fs');const p='../scripts/sync-shared.cjs';if(f.existsSync(p))require('node:child_process').execSync('node '+p,{stdio:'inherit'});else console.log('[prebuild] sync-shared.cjs not found (Docker build) — using committed copy');\"",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/react": "^5.0.4",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.2.1",
    "gsap": "^3.15.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.4",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260503.1",
    "@types/three": "^0.170.0"
  }
}
